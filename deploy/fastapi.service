[Unit]
Description=FastAPI llama.cpp Chatbot
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/opt/fastapi-llm-chatbot/fastapi-app
EnvironmentFile=/opt/fastapi-llm-chatbot/fastapi-app/.env
ExecStart=/opt/fastapi-llm-chatbot/fastapi-app/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
